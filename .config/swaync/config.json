{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-margin-top": 12,
  "control-center-margin-right": 12,
  "control-center-margin-bottom": 12,
  "control-center-width": 380,
  "notification-icon-size": 48,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "timeout": 10,
  "timeout-low": 5,
  "timeout-critical": 0,
  "fit-to-screen": true,
  "control-center-layer": "overlay",
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-touch": true,
  "keyboard-shortcuts": true,
  "text-empty": "You're all caught up",
  "widgets": [
    "title",
    "buttons-grid",
    "mpris",
    "volume",
    "backlight",
    "dnd",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Control Center",
      "clear-all-button": true,
      "button-text": "Clear All"
    },
    "dnd": {
      "text": "Focus Mode"
    },
    "volume": {
      "label": "󰕾"
    },
    "backlight": {
      "label": "󰃠",
      "device": "amdgpu_bl1"
    },
    "buttons-grid": {
      "buttons-per-row": 4,
      "actions": [
        {
          "label": "󰖩",
          "type": "toggle",
          "command": "nmcli radio wifi | grep -q '^enabled' && nmcli radio wifi off || nmcli radio wifi on",
          "update-command": "nmcli radio wifi | grep -q '^enabled' && echo true || echo false",
          "active": true
        },
        {
          "label": "󰂯",
          "type": "toggle",
          "command": "bluetoothctl show | grep -q 'Powered: yes' && bluetoothctl power off || bluetoothctl power on",
          "update-command": "bluetoothctl show | grep -q 'Powered: yes' && echo true || echo false",
          "active": true
        },
        {
          "label": "󰖔",
          "type": "toggle",
          "command": "swaync-client -d -sw",
          "update-command": "swaync-client -D",
          "active": false
        },
        {
          "label": "󰝟",
          "type": "toggle",
          "command": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
          "update-command": "pactl get-sink-mute @DEFAULT_SINK@ | grep -q 'Mute: yes' && echo true || echo false",
          "active": false
        }
      ]
    }
  }
}
