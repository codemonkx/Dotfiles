// Midnight Obsidian Rofi Layout Configuration
configuration {
    modi:                       "drun,run,filebrowser,window";
    show-icons:                 true;
    display-drun:               " ";
    display-run:                " ";
    display-filebrowser:        " ";
    display-window:             "󰕰 ";
    drun-display-format:        "{name}";
    window-format:              "{w} · {c} · {t}";
    click-to-exit:              true;
}

@theme "theme.rasi"
